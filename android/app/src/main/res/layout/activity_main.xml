<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp">

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:paddingBottom="8dp" />

    <TextView android:id="@+id/statusText"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/status_stopped"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <TextView android:id="@+id/luxText"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/lux_placeholder"
        android:textAppearance="?attr/textAppearanceDisplayLarge"
        android:fontFeatureSettings="tnum"
        android:paddingVertical="16dp" />

    <TextView android:id="@+id/sensorReport"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text=""
        android:textAppearance="@style/TextAppearance.Pupil.Mono"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:paddingBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/toggleButton"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/start_broadcasting" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/batteryButton"
        style="?attr/materialButtonTonalStyle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/battery_exemption" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/settingsButton"
        style="?attr/materialButtonTonalStyle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings" />
</LinearLayout>
